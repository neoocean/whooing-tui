/* whooing-tui — 전역 스타일.
 *
 * 화면별 디테일은 각 Screen 의 DEFAULT_CSS 에 둔다 (HomeScreen 등).
 * 본 파일은 모든 화면에 공통 적용되는 최소한의 룰만.
 */

Header {
    background: $accent-darken-1;
}

Footer {
    background: $boost;
}

/* 빈 root (App.compose 직후, HomeScreen push 전 잠깐 보일 수 있음) 의
 * Header/Footer 가 화면을 잡아먹지 않도록 가운데 정렬. */
Screen > Header {
    dock: top;
}

Screen > Footer {
    dock: bottom;
}
