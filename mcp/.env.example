# 후잉 → 사용자 > 계정 > 비밀번호 및 보안 > AI 토큰 발급
# 발급된 토큰은 `__eyJh...` 로 시작 (앞 underscore 2개 포함 전체).
# CL #1 의 audit 도구는 read scope 만 필요.
WHOOING_AI_TOKEN=__eyJh...

# (선택) 여러 섹션을 가진 경우 default 명시 권장.
# 미설정 시 첫 섹션이 자동 선택된다 (의도치 않은 가계부가 잡힐 수 있음).
# WHOOING_SECTION_ID=

# (선택, v0.2.0+) SQLite db + 첨부파일 root. whooing-tui 와 공유.
# 미설정 시 ~/.whooing/ default. 두 앱이 같은 데이터를 본다.
# 옛 <project>/whooing-data.sqlite 도 backward-compat (경고와 함께 동작).
# WHOOING_DATA_DIR=~/.whooing

# (선택, v0.2.0 부터 deprecated 알림) HTML import / attach 도구는 whooing-tui
# 로 이전됨. 본 wrapper 는 더 이상 카드 패스워드 사용 X. 키는 .env 의 다른
# 도구 (TUI) 가 쓰는 자리로 남김.
# WHOOING_CARD_HTML_PASSWORD=

# (선택) 기본값으로 충분.
# WHOOING_BASE_URL=https://whooing.com/api
# WHOOING_HTTP_TIMEOUT=10
# WHOOING_LOG_LEVEL=INFO
