# 후잉 → 사용자 > 계정 > 비밀번호 및 보안 > AI 토큰 발급
# 발급된 토큰은 `__eyJh...` 로 시작 (앞 underscore 2개 포함 전체).
# TUI 는 read 와 write(거래 입력/수정 등) 모두 사용 — 발급 시 양쪽 scope 부여.
WHOOING_AI_TOKEN=__eyJh...

# (선택) 여러 섹션을 가진 경우 default 명시 권장.
# 미설정 시 첫 섹션이 자동 선택된다 (의도치 않은 가계부가 잡힐 수 있음).
# WHOOING_SECTION_ID=

# (선택) 기본값으로 충분.
# WHOOING_BASE_URL=https://whooing.com/api
# WHOOING_HTTP_TIMEOUT=10
# WHOOING_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# .env 탐색 우선순위 (0.6.1+)
#
#   1. 셸 환경변수 (이미 export 된 것이 항상 최우선)
#   2. $WHOOING_ENV (절대 경로 override)
#   3. ~/.config/whooing/.env  ← 권장 (XDG 표준 위치, 단순 path)
#   4. project root/.env       ← 본 파일의 위치 (legacy, backward compat)
#
# 토큰을 한 곳에서만 관리하려면 ~/.config/whooing/.env 로 옮기세요:
#
#   mkdir -p ~/.config/whooing
#   mv .env ~/.config/whooing/.env
#   chmod 600 ~/.config/whooing/.env   # 권장
#
# 본래 위 공통 위치는 archived whooing-mcp-server-wrapper 와 토큰을 공유
# 하기 위해 도입됐다 (2026-05-10). wrapper 종료 후에도 단순하고 발견
# 가능한 path 라 그대로 유지.
# ─────────────────────────────────────────────────────────────────────────
